/* ============================================================================
   DASHBOARD STYLES - Optimized Compact Admin Dashboard with Theme Support
   ============================================================================ */

@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@300;400;500;600;700;800&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

/* ============================================================================
   THEME VARIABLES
   ============================================================================ */

:root {
  /* Dark Theme (Default) */
  --bg-primary: #0f172a;
  --bg-secondary: #1a2847;
  --bg-tertiary: #1a1f3a;
  --text-primary: #ffffff;
  --text-secondary: #cbd5e1;
  --text-tertiary: #93c5fd;
  --border-color: rgba(59, 130, 246, 0.2);
  --accent-primary: #3b82f6;
  --accent-secondary: #8b5cf6;
  --card-bg: rgba(30, 41, 59, 0.7);
  --nav-bg: linear-gradient(180deg, rgba(30, 41, 59, 0.75) 0%, rgba(15, 23, 42, 0.85) 100%);
  --gradient-overlay: linear-gradient(135deg, rgba(15, 23, 42, 0.95) 0%, rgba(26, 40, 71, 0.95) 50%, rgba(15, 23, 42, 0.95) 100%);
  --form-input-bg: rgba(10, 10, 10, 0.8);
  --form-input-border: rgba(59, 130, 246, 0.3);
}

/* Light Theme */
[data-theme="light"] {
  --bg-primary: #FEFBF3;
  --bg-secondary: #F5F0E8;
  --bg-tertiary: #E8E0D5;
  --text-primary: #1A1410;
  --text-secondary: #5A4A40;
  --text-tertiary: #8B7355;
  --border-color: #D4C4B0;
  --accent-primary: #1E3A5F;
  --accent-secondary: #3b82f6;
  --card-bg: rgba(255, 251, 243, 0.85);
  --nav-bg: linear-gradient(180deg, rgba(245, 240, 232, 0.75) 0%, rgba(238, 233, 226, 0.85) 100%);
  --gradient-overlay: linear-gradient(135deg, rgba(245, 240, 232, 0.95) 0%, rgba(232, 224, 213, 0.95) 50%, rgba(254, 251, 243, 0.95) 100%);
  --form-input-bg: #ffffff;
  --form-input-border: #D4C4B0;
}

/* ============================================================================
   ANIMATIONS
   ============================================================================ */

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================================================
   USER DASHBOARD NAVIGATION - VERTICAL LEFT SIDEBAR
   ============================================================================ */

@keyframes shimmer {
  }

  /* ============================================================================
     USER DASHBOARD NAVIGATION - VERTICAL LEFT SIDEBAR
     ============================================================================ */

@keyframes shimmer {
  0%, 100% {
    background-position: -2000px 0;
  }
  100% {
    background-position: calc(2000px + 100%) 0;
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
/* ============================================================================
   USER DASHBOARD NAVIGATION - VERTICAL LEFT SIDEBAR
   ============================================================================ */

.user-dashboard-nav {
  background: linear-gradient(180deg, rgba(30, 41, 59, 0.75) 0%, rgba(15, 23, 42, 0.85) 100%);
  border-right: 1px solid var(--border-color);
  padding: 0;
  position: fixed;
  left: 0;
  top: 0;
  height: 100vh;
  width: 200px;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

.nav-tabs {
  display: flex;
  flex-direction: column;
  gap: 0;
  width: 100%;
  padding-top: 20px;
}

.nav-tab {
  width: 100%;
  padding: 16px 20px;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  border-left: 4px solid transparent;
  text-align: left;
  white-space: nowrap;
}

.nav-tab:hover {
  color: var(--text-primary);
  background: rgba(59, 130, 246, 0.1);
  border-left-color: var(--accent-primary);
}

.nav-tab.active {
  color: var(--accent-primary);
  border-left-color: var(--accent-primary);
  background: rgba(59, 130, 246, 0.05);
}

/* Adjust dashboard layout to accommodate left sidebar */
.user-dashboard-wrapper {
  display: grid;
  grid-template-columns: 200px 1fr;
  grid-template-rows: 1fr;
  min-height: 100vh;
  width: 100%;
}

.user-dashboard-wrapper .dashboard {
  grid-column: 2;
  grid-row: 1;
  margin-left: 0;
}

.user-dashboard-wrapper .user-dashboard-nav {
  grid-column: 1;
  grid-row: 1;
  position: relative;
  height: auto;
  width: auto;
}

/* ============================================================================
   THEME TOGGLE BUTTON
   ============================================================================ */

.theme-toggle-dashboard {
  position: fixed;
  top: 30px;
  right: 30px;
  width: 45px;
  height: 45px;
  border-radius: 50%;
    --form-input-border: #D4C4B0;
  }

  /* ============================================================================
     ANIMATIONS
     ============================================================================ */

  @keyframes slideInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fillAnimation {
    from {
      opacity: 0;
      stroke-dashoffset: 100%;
    }
    to {
      opacity: 1;
      stroke-dashoffset: 0;
    }
  }

  @keyframes shimmer {
    0%, 100% {
      background-position: -2000px 0;
    }
    100% {
      background-position: calc(2000px + 100%) 0;
    }
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================================================
     USER DASHBOARD NAVIGATION - VERTICAL LEFT SIDEBAR
     ============================================================================ */
}

.nav-btn {
  margin: 4px 8px;
  padding: 8px 12px;
  background: var(--card-bg);
  border: 1px solid var(--border-color);
  color: var(--text-secondary);
  border-radius: 6px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.75rem;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  position: relative;
  z-index: 1;
}

.nav-btn:hover {
  background: var(--bg-secondary);
  border-color: var(--accent-primary);
  color: var(--accent-primary);
  transform: translateX(4px);
}

.nav-btn.active {
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
  color: var(--text-primary);
  border-color: var(--accent-primary);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2), inset 0 1px 1px rgba(255, 255, 255, 0.1);
}

/* ============================================================================
   DASHBOARD HEADER
   ============================================================================ */

.dashboard-header {
  grid-column: 2;
  grid-row: 1;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border-color);
  padding: 8px 12px;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  gap: 10px;
  transition: all 0.3s ease;
  position: relative;
  z-index: 100;
}

.dashboard-header h1 {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.01em;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}
/* ============================================================================
   ANIMATIONS
   ============================================================================ */

@keyframes slideInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fillAnimation {
  from {
    opacity: 0;
    stroke-dashoffset: 100%;
  }
  to {
    opacity: 1;
    stroke-dashoffset: 0;
  }
}

@keyframes shimmer {
  0%, 100% {
    background-position: -2000px 0;
  }
  100% {
    background-position: calc(2000px + 100%) 0;
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================================================
   USER DASHBOARD NAVIGATION - VERTICAL LEFT SIDEBAR
  margin: 0;
  position: relative;
  z-index: 10;
}

.dashboard:has(.dashboard-nav) .dashboard-content {
  grid-column: 2;
  padding: 10px 12px;
}

.section {
  margin-bottom: 0;
  margin-top: 0;
  padding: 0;
  background: transparent;
  border-radius: 0;
  border: none;
  width: 100%;
}

.section h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-secondary);
  margin-bottom: 15px;
  margin-top: 15px;
  letter-spacing: -0.01em;
  display: flex;
  align-items: center;
  gap: 8px;
  position: relative;
  z-index: 10;
  transition: all 0.3s ease;
}

.section h3 {
  font-family: 'Playfair Display', serif;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8px;
  letter-spacing: -0.01em;
}

/* ============================================================================
   COMPONENT SECTIONS WITH ROUNDED CORNERS
   ============================================================================ */

.component-section {
  background: var(--card-bg) !important;
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 10px;
  margin-bottom: 8px;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  backdrop-filter: blur(12px);
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  animation: slideInUp 0.6s cubic-bezier(0.23, 1, 0.320, 1);
}

.component-section::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent-primary), transparent);
  opacity: 0.3;
  border-radius: 0;
}

.component-section:hover {
  border-color: var(--accent-secondary);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
}

.component-section h3 {
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 4px;
  background: var(--bg-secondary);
  padding: 4px 8px;
  border-radius: 4px;
  border-left: 2px solid var(--accent-primary);
}

.component-section h3::before {
  display: none;
}

/* ============================================================================
   ANALYTICS REPORT COMPONENT
   ============================================================================ */

.analytics-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 4px;
  margin-top: 4px;
}

.analytics-item {
  background: transparent;
  border: none;
  border-radius: 0;
  padding: 4px;
  text-align: center;
  transition: all 0.3s ease;
  border-bottom: 1px solid var(--border-color);
}

.analytics-item:hover {
  transform: scale(1.03);
  border-bottom-color: var(--accent-primary);
}

.analytics-item label {
  display: block;
  font-size: 0.6rem;
  color: var(--text-tertiary);
  margin-bottom: 2px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.15px;
}

.analytics-item .value {
  font-size: 1.3rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
}

/* ============================================================================
   CHART COMPONENTS
   ============================================================================ */

.chart-wrapper {
  width: 100%;
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4px;
}

.chart-wrapper-radial {
  width: 100%;
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4px;
}

/* ============================================================================
   USER DASHBOARD NAVIGATION
   ============================================================================ */

.user-dashboard-nav {
  background: linear-gradient(180deg, rgba(30, 41, 59, 0.75) 0%, rgba(15, 23, 42, 0.85) 100%);
  border-bottom: 1px solid var(--border-color);
  padding: 0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-tabs {
  display: flex;
  gap: 0;
  max-width: 1200px;
  margin: 0 auto;
}

.nav-tab {
  flex: 1;
  padding: 16px 20px;
  background: transparent;
  border: none;
  color: var(--text-secondary);
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  border-bottom: 3px solid transparent;
  text-align: center;
}

.nav-tab:hover {
  color: var(--text-primary);
  background: rgba(59, 130, 246, 0.1);
}

.nav-tab.active {
  color: var(--accent-primary);
  border-bottom-color: var(--accent-primary);
  background: rgba(59, 130, 246, 0.05);
}

/* ============================================================================
   DROPDOWN SECTION STYLING
   ============================================================================ */

.dropdown-section {
  margin-bottom: 16px;
}

.dropdown-section label {
  display: block;
  font-size: 14px;
  color: var(--text-secondary);
  margin-bottom: 8px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.dropdown-section select,
.form select {
  width: 100%;
  padding: 12px 16px;
  background: var(--form-input-bg);
  border: 1px solid var(--form-input-border);
  border-radius: 8px;
  color: var(--text-primary);
  font-size: 14px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.dropdown-section select:hover,
.form select:hover {
  border-color: rgba(59, 130, 246, 0.6);
  background: rgba(30, 41, 59, 0.8);
}

.dropdown-section select:focus,
.form select:focus {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
  background: rgba(30, 41, 59, 0.9);
}

.dropdown-section select option {
  background: var(--bg-primary);
  color: var(--text-primary);
}

[data-theme="light"] .dropdown-section select option {
  background: #ffffff;
  color: #000000;
}

/* ============================================================================
   RECHARTS LEGEND STYLING - Theme-aware text color
   ============================================================================ */

/* Global SVG text styling for recharts */
svg text {
  fill: var(--text-primary) !important;
}

svg tspan {
  fill: var(--text-primary) !important;
}

.recharts-legend-wrapper {
  color: var(--text-primary) !important;
}

.recharts-legend-wrapper text,
.recharts-legend-item text,
.recharts-legend-item-text {
  fill: var(--text-primary) !important;
  color: var(--text-primary) !important;
  font-size: 14px !important;
}

/* Ensure SVG text elements have correct fill */
svg .recharts-legend-item-text {
  fill: var(--text-primary) !important;
}

/* Dark theme - white text for all SVG elements */
[data-theme="dark"] svg text,
[data-theme="dark"] svg tspan {
  fill: #ffffff !important;
  color: #ffffff !important;
}

[data-theme="dark"] .recharts-legend-wrapper,
[data-theme="dark"] .recharts-legend-wrapper text,
[data-theme="dark"] .recharts-legend-item text,
[data-theme="dark"] .recharts-legend-item-text,
[data-theme="dark"] svg .recharts-legend-item-text {
  fill: #ffffff !important;
  color: #ffffff !important;
  stroke: none !important;
}

/* Light theme - black text for all SVG elements */
[data-theme="light"] svg text,
[data-theme="light"] svg tspan {
  fill: #000000 !important;
  color: #000000 !important;
}

[data-theme="light"] .recharts-legend-wrapper,
[data-theme="light"] .recharts-legend-wrapper text,
[data-theme="light"] .recharts-legend-item text,
[data-theme="light"] .recharts-legend-item-text,
[data-theme="light"] svg .recharts-legend-item-text {
  fill: #000000 !important;
  color: #000000 !important;
  stroke: none !important;
}

/* ============================================================================
   WORKERS TABLE
   ============================================================================ */

.workers-table-wrapper {
  width: 100%;
  overflow-x: auto;
  margin-top: 8px;
}

.workers-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.85rem;
}

.workers-table thead {
  background: transparent;
  border-bottom: 1px solid var(--border-color);
}

.workers-table th {
  padding: 8px 10px;
  text-align: left;
  font-weight: 700;
  color: var(--text-secondary);
  text-transform: uppercase;
  font-size: 0.75rem;
  letter-spacing: 0.3px;
}

.workers-table tbody tr {
  border-bottom: 1px solid var(--border-color);
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.workers-table tbody tr:hover {
  background: var(--card-bg);
}

.workers-table td {
  padding: 8px 10px;
  color: var(--text-secondary);
  word-break: break-word;
}

.workers-table td:first-child {
  font-weight: 600;
  color: var(--accent-primary);
}

/* ============================================================================
   RESPONSIVE GRID FOR COMPONENTS
   ============================================================================ */

.components-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}

@media (max-width: 1400px) {
  .components-grid {
    grid-template-columns: 1fr;
  }

  .component-section {
    padding: 10px;
  }

  .charts-section {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .dashboard {
    grid-template-columns: 1fr;
  }

  .dashboard-nav {
    position: relative;
    width: 100%;
    height: auto;
    flex-direction: row;
    border-right: none;
    border-bottom: 1px solid var(--border-color);
    padding: 8px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .nav-btn {
    margin: 3px;
    padding: 6px 10px;
    font-size: 0.7rem;
  }

  .dashboard-header {
    grid-column: 1;
    padding: 8px 12px;
    flex-wrap: wrap;
  }

  .dashboard-header h1 {
    font-size: 1rem;
  }

  .dashboard-content {
    grid-column: 1;
    padding: 10px;
  }

  .components-grid {
    grid-template-columns: 1fr;
  }

  .chart-wrapper,
  .chart-wrapper-radial {
    height: 180px;
  }

  .analytics-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .workers-list,
  .tasks-list,
  .issues-list {
    grid-template-columns: 1fr;
  }
}

.stat-card {
  background: transparent;
  border: none;
  border-bottom: 1px solid rgba(59, 130, 246, 0.15);
  border-radius: 0;
  padding: 6px 0;
  text-align: center;
  box-shadow: none;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  backdrop-filter: none;
  position: relative;
  overflow: hidden;
}

.stat-card:hover {
  transform: scale(1.02);
  border-bottom-color: var(--accent-secondary);
  box-shadow: none;
}

.stat-card h3 {
  font-size: 0.6rem;
  color: var(--text-tertiary);
  margin-bottom: 2px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.2px;
}

.stat-number {
  font-size: 1.2rem;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
}

/* ============================================================================
   CHARTS SECTION
   ============================================================================ */

.charts-section {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
  margin-bottom: 10px;
}

.chart-card {
  background: linear-gradient(135deg, rgba(20, 20, 20, 0.7) 0%, rgba(15, 15, 15, 0.6) 100%);
  border: 1px solid rgba(59, 130, 246, 0.2);
  border-radius: 8px;
  padding: 8px;
  box-shadow: none;
  backdrop-filter: none;
  position: relative;
  overflow: hidden;
}

.chart-card h3 {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}

.chart-container {
  width: 100%;
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ============================================================================
   PREMIUM CARDS - ISSUE, TASK, WORKER
   ============================================================================ */

.issue-card {
  background: rgba(59, 130, 246, 0.08);
  border: 1px solid rgba(59, 130, 246, 0.2);
  border-radius: 6px;
  padding: 6px;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  backdrop-filter: none;
  position: relative;
  overflow: hidden;
}

.issue-card h4 {
  font-size: 1rem;
  font-weight: 700;
  color: #93c5fd;
  margin-bottom: 6px;
}

.issue-card-user p {
  color: #cbd5e1;
  margin-bottom: 6px;
  font-size: 0.9rem;
  font-weight: 400;
}

.issue-card p {
  color: #cbd5e1;
  margin-bottom: 4px;
  font-size: 0.8rem;
  font-weight: 400;
}

.issue-card img {
  width: 100%;
  height: auto;
  max-height: 100px;
  border-radius: 4px;
  margin-top: 4px;
  object-fit: cover;
}

.task-card,
.worker-card {
  background: rgba(59, 130, 246, 0.08);
  border: 1px solid rgba(59, 130, 246, 0.2);
  border-radius: 6px;
  padding: 10px 12px;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  box-shadow: none;
  backdrop-filter: none;
  position: relative;
  overflow: visible;
  margin-bottom: 8px;
}

.task-card::before,
.worker-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 0;
  background: transparent;
}

.issue-card:hover {
  transform: translateY(-2px);
  border-color: rgba(59, 130, 246, 0.4);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15);
  background: rgba(59, 130, 246, 0.15);
}

.task-card:hover,
.worker-card:hover {
  transform: translateY(-2px);
  border-color: rgba(59, 130, 246, 0.4);
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
  background: rgba(59, 130, 246, 0.15);
}

.priority-task-card {
  cursor: pointer;
}

.priority-task-card.selected {
  border-color: rgba(59, 130, 246, 0.7);
  box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.6);
  background: rgba(59, 130, 246, 0.12);
}

.issue-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 3px;
}

.issue-header h3,
.task-card h4,
.worker-card h4 {
  font-size: 1rem;
  font-weight: 700;
  color: #93c5fd;
}

.task-card p,
.worker-card p {
  color: #cbd5e1;
  margin-bottom: 5px;
  font-size: 0.85rem;
  font-weight: 500;
  word-break: break-word;
  overflow-wrap: anywhere;
}

/* Completed cards now use status-specific styling via :has() selector */

.issue-card .explanation {
  background: rgba(59, 130, 246, 0.1);
  border-left: 3px solid #93c5fd;
  padding: 6px 8px;
  border-radius: 3px;
  margin-top: 6px;
  font-size: 0.75rem;
  color: #93c5fd;
  line-height: 1.4;
}

/* ============================================================================
   ISSUE CARD STATUS SPECIFIC COLORS
   ============================================================================ */

/* Resolved - Green */
.issue-card:has(.status-Resolved) {
  background: rgba(34, 197, 94, 0.08);
  border-color: rgba(34, 197, 94, 0.2);
}

.issue-card:has(.status-Resolved):hover {
  border-color: rgba(34, 197, 94, 0.4);
  box-shadow: 0 4px 16px rgba(34, 197, 94, 0.15);
  background: rgba(34, 197, 94, 0.15);
}

.issue-card:has(.status-Resolved) h4 {
  color: #86efac;
}

/* Assigned - Blue */
.issue-card:has(.status-Assigned) {
  background: rgba(59, 130, 246, 0.08);
  border-color: rgba(59, 130, 246, 0.2);
}

.issue-card:has(.status-Assigned):hover {
  border-color: rgba(59, 130, 246, 0.4);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15);
  background: rgba(59, 130, 246, 0.15);
}

.issue-card:has(.status-Assigned) h4 {
  color: #93c5fd;
}

/* Rejected - Red */
.issue-card:has(.status-Rejected) {
  background: rgba(239, 68, 68, 0.08);
  border-color: rgba(239, 68, 68, 0.2);
}

.issue-card:has(.status-Rejected):hover {
  border-color: rgba(239, 68, 68, 0.4);
  box-shadow: 0 4px 16px rgba(239, 68, 68, 0.15);
  background: rgba(239, 68, 68, 0.15);
}

.issue-card:has(.status-Rejected) h4 {
  color: #fca5a5;
}

/* Reported - Orange (default blue for other statuses) */
.issue-card:has(.status-Reported) {
  background: rgba(59, 130, 246, 0.08);
  border-color: rgba(59, 130, 246, 0.2);
}

.issue-card:has(.status-Reported):hover {
  border-color: rgba(59, 130, 246, 0.4);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15);
  background: rgba(59, 130, 246, 0.15);
}

/* ============================================================================
   TASK CARD STATUS SPECIFIC COLORS
   ============================================================================ */

/* Scheduled - Blue */
.task-card:has(.status-Scheduled),
.worker-task-card:has(.status-Scheduled) {
  background: rgba(59, 130, 246, 0.08) !important;
  border-color: rgba(59, 130, 246, 0.2) !important;
}

.task-card:has(.status-Scheduled):hover,
.worker-task-card:has(.status-Scheduled):hover {
  border-color: rgba(59, 130, 246, 0.4);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.15);
  background: rgba(59, 130, 246, 0.15);
}

.task-card:has(.status-Scheduled) h4,
.worker-task-card:has(.status-Scheduled) h4 {
  color: #93c5fd !important;
}

/* In Progress - Yellow */
.task-card:has(.status-InProgress),
.worker-task-card:has(.status-InProgress) {
  background: rgba(245, 158, 11, 0.08) !important;
  border-color: rgba(245, 158, 11, 0.2) !important;
}

.task-card:has(.status-InProgress):hover,
.worker-task-card:has(.status-InProgress):hover {
  border-color: rgba(245, 158, 11, 0.4);
  box-shadow: 0 4px 16px rgba(245, 158, 11, 0.15);
  background: rgba(245, 158, 11, 0.15);
}

.task-card:has(.status-InProgress) h4,
.worker-task-card:has(.status-InProgress) h4 {
  color: #fbbf24 !important;
}

/* Completed - Green */
.task-card:has(.status-Completed),
.worker-task-card:has(.status-Completed) {
  background: rgba(34, 197, 94, 0.08) !important;
  border-color: rgba(34, 197, 94, 0.2) !important;
}

.task-card:has(.status-Completed):hover,
.worker-task-card:has(.status-Completed):hover {
  border-color: rgba(34, 197, 94, 0.4);
  box-shadow: 0 4px 16px rgba(34, 197, 94, 0.15);
  background: rgba(34, 197, 94, 0.15);
}

.task-card:has(.status-Completed) h4,
.worker-task-card:has(.status-Completed) h4 {
  color: #86efac !important;
}

/* Rejected - Red */
.task-card:has(.status-Rejected),
.worker-task-card:has(.status-Rejected) {
  background: rgba(239, 68, 68, 0.08) !important;
  border-color: rgba(239, 68, 68, 0.2) !important;
}

.task-card:has(.status-Rejected):hover,
.worker-task-card:has(.status-Rejected):hover {
  border-color: rgba(239, 68, 68, 0.4);
  box-shadow: 0 4px 16px rgba(239, 68, 68, 0.15);
  background: rgba(239, 68, 68, 0.15);
}

.task-card:has(.status-Rejected) h4,
.worker-task-card:has(.status-Rejected) h4 {
  color: #fca5a5 !important;
}

/* ============================================================================
   STATUS BADGES - COLOR CODED
   ============================================================================ */

.status-badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 5px;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.3px;
  backdrop-filter: blur(10px);
}

.status-Reported {
  background: rgba(59, 130, 246, 0.15);
  color: #93c5fd;
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.status-Assigned {
  background: rgba(59, 130, 246, 0.15);
  color: #93c5fd;
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.status-Scheduled {
  background: rgba(59, 130, 246, 0.15);
  color: #93c5fd;
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.status-Resolved {
  background: rgba(59, 130, 246, 0.15);
  color: #93c5fd;
  border: 1px solid rgba(59, 130, 246, 0.3);
}

.status-Pending {
  background: rgba(59, 130, 246, 0.25);
  color: #60a5fa;
  border: 1px solid rgba(59, 130, 246, 0.5);
  font-weight: 800;
}

.status-InProgress {
  background: rgba(245, 158, 11, 0.2);
  color: #fbbf24;
  border: 1px solid rgba(245, 158, 11, 0.5);
}

.status-Completed {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.15) 0%, rgba(74, 222, 128, 0.1) 100%);
  color: #86efac;
  border: 1px solid rgba(34, 197, 94, 0.4);
}

.status-Rejected {
  background: rgba(239, 68, 68, 0.15);
  color: #fca5a5;
  border: 1px solid rgba(239, 68, 68, 0.3);
}

/* ============================================================================
   WEEK SUMMARY
   ============================================================================ */

.week-summary {
  background: transparent;
  border: none;
  border-top: 1px solid rgba(59, 130, 246, 0.15);
  border-radius: 0;
  padding: 8px 0;
  box-shadow: none;
  backdrop-filter: none;
  margin-top: 8px;
}

.weeks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  gap: 6px;
  margin-top: 6px;
}

.task-stats {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-top: 3px;
  padding-top: 3px;
  border-top: 1px solid rgba(59, 130, 246, 0.1);
}

.task-stats span {
  font-size: 0.65rem;
  font-weight: 600;
  color: #94a3b8;
}

/* ============================================================================
   LISTS AND LAYOUTS
   ============================================================================ */

.issues-list {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 15px;
}

.workers-list,
.tasks-list {
  display: grid;
  gap: 6px;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
}

/* ============================================================================
   FORMS
   ============================================================================ */

.form {
  background: transparent;
  border: 1px solid rgba(59, 130, 246, 0.15);
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 15px;
  display: flex;
  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================================================
     USER DASHBOARD NAVIGATION - VERTICAL LEFT SIDEBAR
     ============================================================================ */

.form h3 {
  margin-bottom: 10px;
  font-size: 1rem;
  color: var(--text-primary);
  font-weight: 700;
}

.form input,
.form select,
.form textarea {
  padding: 10px 12px;
  background: var(--form-input-bg);
  border: 1px solid var(--form-input-border);
  border-radius: 6px;
  color: var(--text-primary);
  font-size: 0.9rem;
  font-family: inherit;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.form select option {
  background: var(--form-input-bg);
  color: var(--text-primary);
  padding: 8px;
}

.form input::placeholder,
.form textarea::placeholder {
  color: var(--text-secondary);
}

.form input:focus,
.form select:focus,
.form textarea:focus {
  outline: none;
  border-color: var(--accent-primary);
  background: rgba(59, 130, 246, 0.05);
  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
}

.form button {
  padding: 12px 24px;
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  color: var(--text-primary);
  border: none;
  border-radius: 8px;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  box-shadow: 0 6px 16px rgba(59, 130, 246, 0.35);
  align-self: flex-start;
}

.form button:hover:not(:disabled) {
  background: #0ea5e9;
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(14, 165, 233, 0.4);
}

.form button:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

/* Field Wrapper Styles */
.location-field-wrapper {
  border: none;
  border-radius: 0;
  padding: 0;
  background: transparent;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: none;
}

.location-field-wrapper:focus-within {
  border-color: transparent;
  box-shadow: none;
}

[data-theme="light"] .location-field-wrapper:focus-within {
  border-color: transparent;
  box-shadow: none;
}

.image-field-wrapper {
  border: none;
  border-radius: 0;
  padding: 0;
  background: transparent;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: none;
}

.image-field-wrapper:focus-within {
  border-color: transparent;
  box-shadow: none;
}

[data-theme="light"] .image-field-wrapper:focus-within {
  border-color: transparent;
  box-shadow: none;
}

.location-controls {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.form .user-action-btn {
  width: 180px;
  height: 45px;
  padding: 0 10px;
  border: 1px solid rgba(59, 130, 246, 0.95);
  border-radius: 10px;
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  color: #ffffff;
  font-weight: 700;
  font-size: 1.02rem;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  box-shadow: 0 8px 18px rgba(37, 99, 235, 0.32);
  transition: all 0.25s ease;
}

.form .user-action-btn:hover:not(:disabled) {
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
  transform: translateY(-2px);
  box-shadow: 0 12px 22px rgba(37, 99, 235, 0.4);
}

.form .user-action-btn:disabled {
  opacity: 0.55;
  cursor: not-allowed;
  box-shadow: none;
}

.location-btn {
  min-width: 180px;
  height: 40px;
  padding: 0 16px;
  border: 1px solid rgba(79, 70, 229, 0.9);
  border-radius: 10px;
  font-weight: 700;
  font-size: 0.82rem;
  color: #ffffff;
  background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
  cursor: pointer;
  transition: all 0.25s ease;
  box-shadow: 0 5px 14px rgba(67, 56, 202, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.location-btn.secondary {
  background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
  border-color: rgba(79, 70, 229, 0.9);
  box-shadow: 0 5px 14px rgba(67, 56, 202, 0.38);
}

.location-btn.ghost {
  background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
  border-color: rgba(79, 70, 229, 0.9);
  color: #ffffff;
  box-shadow: 0 5px 14px rgba(67, 56, 202, 0.38);
}

.location-btn.ghost:hover:not(:disabled) {
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  border-color: rgba(99, 102, 241, 0.95);
  color: #ffffff;
}

.location-btn:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 18px rgba(67, 56, 202, 0.45);
}

.location-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.map-picker-wrapper {
  border: 1px solid var(--form-input-border);
  border-radius: 10px;
  padding: 8px;
  background: rgba(59, 130, 246, 0.15);
  border-color: rgba(59, 130, 246, 0.3);
}

[data-theme="light"] .map-picker-wrapper {
  background: rgba(59, 130, 246, 0.1);
  border-color: rgba(59, 130, 246, 0.2);
}

[data-theme="dark"] .map-picker-wrapper {
  background: rgba(59, 130, 246, 0.15);
  border-color: rgba(59, 130, 246, 0.3);
}

.issue-map {
  width: 100%;
  height: 320px;
  border-radius: 10px;
}

.selected-location-box {
  border: 1px solid rgba(25, 118, 210, 0.45);
  background: rgba(25, 118, 210, 0.12);
  border-radius: 8px;
  padding: 10px;
  color: var(--text-primary);
}

.selected-location-box p {
  margin-bottom: 4px;
}

.location-help-text {
  color: var(--text-secondary);
  font-size: 0.82rem;
  margin: 2px 0;
}

.image-upload-controls {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.image-upload-controls .location-btn {
  min-width: 180px;
  height: 40px;
  padding: 0 16px;
  font-size: 0.82rem;
}

.image-upload-controls .location-btn.secondary {
  background: linear-gradient(135deg, #4f46e5 0%, #4338ca 100%);
  box-shadow: 0 5px 14px rgba(67, 56, 202, 0.38);
}

.chat-panel-shell {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.chat-panel-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.chat-filter-controls {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
}

.chat-issue-select {
  min-width: 260px;
  padding: 10px 12px;
  background: var(--form-input-bg);
  border: 1px solid var(--form-input-border);
  border-radius: 8px;
  color: var(--text-primary);
}

.chat-history {
  border: 1px solid var(--border-color);
  border-radius: 10px;
  padding: 12px;
  min-height: 320px;
  max-height: 460px;
  overflow-y: auto;
  background: rgba(59, 130, 246, 0.15);
  border-color: rgba(59, 130, 246, 0.3);
}

[data-theme="light"] .chat-history {
  background: #ffffff;
  border-color: rgba(59, 130, 246, 0.2);
  color: #1e293b;
}

[data-theme="dark"] .chat-history {
  background: rgba(30, 58, 138, 0.3);
  border-color: rgba(59, 130, 246, 0.3);
  color: #f1f5f9;
}

.chat-message-row {
  display: flex;
  margin-bottom: 10px;
}

.chat-message-row.mine {
  justify-content: flex-end;
}

.chat-message-row.other {
  justify-content: flex-start;
}

.chat-message-bubble {
  max-width: 80%;
  border-radius: 10px;
  padding: 10px;
  border: 1px solid transparent;
}

.chat-message-bubble.mine {
  background: rgba(37, 99, 235, 0.24);
  border-color: rgba(37, 99, 235, 0.45);
}

[data-theme="light"] .chat-message-bubble.mine {
  background: rgba(59, 130, 246, 0.15);
  border-color: rgba(59, 130, 246, 0.3);
}

.chat-message-bubble.other {
  background: rgba(51, 65, 85, 0.55);
  border-color: rgba(148, 163, 184, 0.35);
}

[data-theme="light"] .chat-message-bubble.other {
  background: rgba(226, 232, 240, 0.8);
  border-color: rgba(148, 163, 184, 0.35);
}

.chat-message-meta {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  font-size: 0.75rem;
  color: #cbd5e1;
  margin-bottom: 6px;
}

[data-theme="light"] .chat-message-meta {
  color: #64748b;
}

.chat-message-bubble p {
  color: #f1f5f9;
  margin: 0;
  white-space: pre-wrap;
  word-break: break-word;
}

[data-theme="light"] .chat-message-bubble p {
  color: #1e293b;
}

.chat-message-issue {
  margin-top: 8px;
  font-size: 0.75rem;
  color: #93c5fd;
}

[data-theme="light"] .chat-message-issue {
  color: #0284c7;
}

.chat-compose-row {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.chat-input {
  width: 100%;
  padding: 10px 12px;
  background: rgba(59, 130, 246, 0.15);
  border: 1px solid rgba(59, 130, 246, 0.3);
  border-radius: 8px;
  color: #ffffff;
  resize: vertical;
  min-height: 90px;
}

[data-theme="light"] .chat-input {
  background: #ffffff;
  color: #1e293b;
  border-color: rgba(59, 130, 246, 0.3);
}

[data-theme="dark"] .chat-input {
  background: rgba(30, 58, 138, 0.3);
  color: #ffffff;
  border-color: rgba(59, 130, 246, 0.4);
}

.form-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 20px;
  padding-top: 16px;
  border-top: 1px solid rgba(124, 58, 237, 0.2);
}

.form-reset-btn {
  padding: 7px 12px;
  background: transparent;
  color: #94a3b8;
  border: 1.5px solid #94a3b8;
  border-radius: 5px;
  cursor: pointer;
  font-weight: 500;
  font-size: 0.85rem;
  transition: all 0.3s ease;
}

.form-reset-btn:hover:not(:disabled) {
  background: rgba(148, 163, 184, 0.08);
  border-color: #cbd5e1;
  color: #cbd5e1;
  transform: translateY(-1px);
}

.issue-report-btn {
  background: linear-gradient(135deg, #dc2626 0%, #f97316 100%) !important;
  border: 1px solid rgba(249, 115, 22, 0.9);
  box-shadow: 0 8px 22px rgba(239, 68, 68, 0.38) !important;
  letter-spacing: 0.2px;
}

.issue-report-btn:hover:not(:disabled) {
  background: linear-gradient(135deg, #ef4444 0%, #fb923c 100%) !important;
  box-shadow: 0 12px 30px rgba(249, 115, 22, 0.45) !important;
  transform: translateY(-3px);
}

.logout-btn {
  padding: 10px 16px;
  background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  color: #ffffff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
  box-shadow: 0 4px 10px rgba(251, 191, 36, 0.3);
}

.logout-btn:hover:not(:disabled) {
  transform: translateY(-1px);
  box-shadow: 0 6px 16px rgba(251, 191, 36, 0.4);
}

.section-head-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
  margin-bottom: 20px;
}

.refresh-btn {
  padding: 10px 16px;
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  color: #ffffff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.3s ease;
}

.refresh-btn:hover:not(:disabled) {
  transform: translateY(-1px);
}

.user-refresh-btn {
  background: linear-gradient(135deg, #059669 0%, #10b981 100%);
  border: 1px solid rgba(16, 185, 129, 0.9);
  box-shadow: 0 8px 22px rgba(5, 150, 105, 0.35);
  font-weight: 700;
}

.user-refresh-btn:hover:not(:disabled) {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  box-shadow: 0 12px 28px rgba(16, 185, 129, 0.45);
  transform: translateY(-2px);
}

/* ============================================================================
   STATS GRID - PREMIUM CARDS WITH GRADIENTS
   ============================================================================ */

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 6px;
  margin-bottom: 8px;
}

.worker-summary-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(120px, 1fr));
  gap: 8px;
  margin-bottom: 12px;
  border-top: 1px solid rgba(59, 130, 246, 0.2);
  border-bottom: 1px solid rgba(59, 130, 246, 0.15);
  padding: 10px 0;
}

.worker-task-columns {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
  align-items: start;
}

.worker-task-card {
  min-height: 126px;
}

.worker-section-subtitle,
.worker-empty-text {
  color: #94a3b8;
  margin-bottom: 8px;
  font-size: 0.85rem;
}

[data-theme="light"] .worker-section-subtitle,
[data-theme="light"] .worker-empty-text {
  color: #64748b;
}

[data-theme="dark"] .worker-section-subtitle,
[data-theme="dark"] .worker-empty-text {
  color: #cbd5e1;
}

/* ============================================================================
   ERROR MESSAGE
   ============================================================================ */

.error-message {
  background: rgba(239, 68, 68, 0.2);
  border: 2px solid rgba(239, 68, 68, 0.6);
  border-left: 3px solid #ef4444;
  border-radius: 6px;
  color: #fecaca;
  padding: 10px 14px;
  margin-bottom: 12px;
  margin-top: 4px;
  text-align: left;
  font-size: 0.8rem;
  animation: slideDown 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  font-weight: 600;
  z-index: 1000;
}

.success-message {
  background: rgba(34, 197, 94, 0.2);
  border: 1px solid rgba(34, 197, 94, 0.5);
  border-left: 3px solid #22c55e;
  border-radius: 6px;
  color: #86efac;
  padding: 10px 14px;
  margin-bottom: 12px;
  text-align: left;
  font-size: 0.85rem;
  animation: slideDown 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  font-weight: 600;
}

/* ============================================================================
   WORKER DASHBOARD BUTTONS
   ============================================================================ */

.view-btn,
.back-btn {
  padding: 6px 14px;
  background: rgba(59, 130, 246, 0.15);
  color: #93c5fd;
  border: 1px solid rgba(59, 130, 246, 0.3);
  border-radius: 5px;
  font-weight: 600;
  font-size: 0.85rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.view-btn:hover,
.back-btn:hover {
  background: rgba(59, 130, 246, 0.25);
  border-color: rgba(59, 130, 246, 0.5);
  color: #60a5fa;
}

.accept-btn {
  padding: 8px 16px;
  background: rgba(34, 197, 94, 0.15);
  color: #86efac;
  border: 1px solid rgba(34, 197, 94, 0.3);
  border-radius: 5px;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  margin-right: 8px;
}

.accept-btn:hover {
  background: rgba(34, 197, 94, 0.25);
  border-color: rgba(34, 197, 94, 0.5);
  color: #bbf7d0;
}

.accept-btn.selected {
  background: rgba(34, 197, 94, 0.3);
  border-color: #22c55e;
  color: #bbf7d0;
  box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.1);
}

.reject-btn {
  padding: 8px 16px;
  background: rgba(239, 68, 68, 0.15);
  color: #fca5a5;
  border: 1px solid rgba(239, 68, 68, 0.3);
  border-radius: 5px;
  font-weight: 600;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.reject-btn:hover {
  background: rgba(239, 68, 68, 0.25);
  border-color: rgba(239, 68, 68, 0.5);
  color: #f87171;
}

.reject-btn.selected {
  background: rgba(239, 68, 68, 0.3);
  border-color: #ef4444;
  color: #f87171;
  box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.1);
}

.submit-btn,
.complete-btn {
  padding: 10px 20px;
  background: #3b82f6;
  color: #ffffff;
  border: none;
  border-radius: 6px;
  font-weight: 700;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.25);
}

.submit-btn:hover:not(:disabled),
.complete-btn:hover:not(:disabled) {
  background: #0ea5e9;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(59, 130, 246, 0.35);
}

.submit-btn:disabled,
.complete-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.button-group {
  display: flex;
  gap: 12px;
  margin: 12px 0;
  flex-wrap: wrap;
}

/* ============================================================================
   TASK DETAIL & SECTION STYLES
   ============================================================================ */

.task-detail {
  background: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 8px;
  padding: 16px;
  margin-top: 12px;
  animation: slideInUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.task-detail h3 {
  color: #D9CCC3;
  font-size: 1.1rem;
  margin-bottom: 12px;
  font-weight: 700;
}

.task-detail p {
  color: #D9CCC3;
  margin-bottom: 8px;
  font-size: 0.9rem;
  line-height: 1.5;
}

.task-detail p strong {
  color: #E5D4C4;
  font-weight: 700;
}

.task-section {
  margin-bottom: 16px;
}

.task-section h3 {
  color: #93c5fd;
  font-size: 1rem;
  margin-bottom: 10px;
  font-weight: 700;
  padding: 8px 0;
  border-bottom: 2px solid rgba(59, 130, 246, 0.2);
}

.response-form {
  background: rgba(59, 130, 246, 0.08);
  border: 1px solid var(--border-color);
  border-radius: 6px;
  padding: 14px;
  margin-top: 14px;
}

.response-form h4 {
  color: #D9CCC3;
  font-size: 0.95rem;
  margin-bottom: 10px;
  font-weight: 700;
}

.response-form textarea {
  width: 100%;
  padding: 10px 12px;
  background: rgba(10, 10, 10, 0.8);
  border: 1px solid rgba(59, 130, 246, 0.3);
  border-radius: 6px;
  color: #E5D4C4;
  font-size: 0.9rem;
  font-family: inherit;
  margin: 10px 0;
  resize: vertical;
  min-height: 80px;
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.response-form textarea:focus {
  outline: none;
  border-color: rgba(59, 130, 246, 0.6);
  background: rgba(59, 130, 246, 0.05);
  box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.1);
}

/* ============================================================================
   CHARTS CONTAINER - WORKER DASHBOARD PROGRESS
   ============================================================================ */

.charts-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-top: 16px;
}

.chart-box {
  background: rgba(59, 130, 246, 0.05);
  border: 1px solid rgba(59, 130, 246, 0.15);
  border-radius: 8px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  transition: all 0.3s cubic-bezier(0.23, 1, 0.320, 1);
}

.chart-box:hover {
  border-color: rgba(59, 130, 246, 0.3);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.1);
  background: rgba(59, 130, 246, 0.1);
}

.chart-box h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: #93c5fd;
  margin-bottom: 14px;
  text-align: center;
}

.completion-chart-box,
.tasks-chart-box {
  min-height: 350px;
}

/* Recharts styling */
.recharts-surface {
  background: transparent !important;
}

.recharts-default-tooltip {
  background: rgba(10, 10, 10, 0.95) !important;
  border: 1px solid rgba(59, 130, 246, 0.3) !important;
  border-radius: 6px !important;
}

.recharts-tooltip-label {
  color: #E5D4C4 !important;
}

.recharts-tooltip-item {
  color: #60a5fa !important;
}

.recharts-text {
  fill: #000000 !important;
  font-size: 0.75rem !important;
}

.recharts-cartesian-axis-tick {
  fill: #000000 !important;
}

/* ============================================================================
   LIGHT THEME OVERRIDES
   ============================================================================ */

[data-theme="light"] .status-Reported,
[data-theme="light"] .status-Assigned,
[data-theme="light"] .status-Scheduled,
[data-theme="light"] .status-Resolved {
  background: rgba(30, 58, 95, 0.12);
  color: #1E3A5F;
  border: 1px solid rgba(30, 58, 95, 0.3);
}

[data-theme="light"] .status-Rejected {
  background: rgba(239, 68, 68, 0.12);
  color: #dc2626;
  border: 1px solid rgba(239, 68, 68, 0.3);
}

[data-theme="light"] .status-InProgress {
  background: rgba(245, 158, 11, 0.12);
  color: #d97706;
  border: 1px solid rgba(245, 158, 11, 0.3);
}

[data-theme="light"] .status-Completed {
  background: rgba(34, 197, 94, 0.12);
  color: #16a34a;
  border: 1px solid rgba(34, 197, 94, 0.3);
}

[data-theme="light"] .status-Pending {
  background: rgba(30, 58, 95, 0.2);
  color: #1E3A5F;
  border: 1px solid rgba(30, 58, 95, 0.4);
  font-weight: 800;
}

[data-theme="light"] .week-summary {
  border-top: 1px solid rgba(30, 58, 95, 0.12);
}

[data-theme="light"] .task-stats {
  border-top: 1px solid rgba(30, 58, 95, 0.08);
}

[data-theme="light"] .form {
  border: 1px solid rgba(30, 58, 95, 0.12);
}

[data-theme="light"] .form input:focus,
[data-theme="light"] .form select:focus,
[data-theme="light"] .form textarea:focus {
  background: rgba(30, 58, 95, 0.05);
  box-shadow: 0 0 0 2px rgba(30, 58, 95, 0.1);
}

[data-theme="light"] .form button {
  background: linear-gradient(135deg, #1E3A5F 0%, #3b82f6 100%);
  box-shadow: 0 6px 16px rgba(30, 58, 95, 0.25);
}

[data-theme="light"] .form button:hover:not(:disabled) {
  background: #0ea5e9;
  box-shadow: 0 8px 24px rgba(14, 165, 233, 0.35);
}

[data-theme="light"] .form .user-action-btn {
  background: linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
  border-color: rgba(59, 130, 246, 0.9);
  color: #ffffff;
  box-shadow: 0 8px 18px rgba(37, 99, 235, 0.3);
}

[data-theme="light"] .form .user-action-btn:hover:not(:disabled) {
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 100%);
  box-shadow: 0 10px 22px rgba(37, 99, 235, 0.36);
}

[data-theme="light"] .issue-report-btn {
  background: linear-gradient(135deg, #dc2626 0%, #f97316 100%) !important;
  border-color: rgba(249, 115, 22, 0.8);
  box-shadow: 0 8px 22px rgba(239, 68, 68, 0.3) !important;
}

[data-theme="light"] .issue-report-btn:hover:not(:disabled) {
  background: linear-gradient(135deg, #ef4444 0%, #fb923c 100%) !important;
  box-shadow: 0 10px 24px rgba(249, 115, 22, 0.35) !important;
}

[data-theme="light"] .user-refresh-btn {
  background: linear-gradient(135deg, #059669 0%, #10b981 100%);
  border-color: rgba(16, 185, 129, 0.8);
  box-shadow: 0 8px 20px rgba(5, 150, 105, 0.28);
}

[data-theme="light"] .user-refresh-btn:hover:not(:disabled) {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
  box-shadow: 0 10px 24px rgba(16, 185, 129, 0.34);
}

[data-theme="light"] .view-btn,
[data-theme="light"] .back-btn {
  background: rgba(30, 58, 95, 0.12);
  color: #1E3A5F;
  border: 1px solid rgba(30, 58, 95, 0.3);
}

[data-theme="light"] .view-btn:hover,
[data-theme="light"] .back-btn:hover {
  background: rgba(30, 58, 95, 0.2);
  border-color: rgba(30, 58, 95, 0.5);
  color: #3b82f6;
}

[data-theme="light"] .submit-btn,
[data-theme="light"] .complete-btn {
  background: #1E3A5F;
  color: #ffffff;
  box-shadow: 0 4px 12px rgba(30, 58, 95, 0.25);
}

[data-theme="light"] .submit-btn:hover:not(:disabled),
[data-theme="light"] .complete-btn:hover:not(:disabled) {
  background: #3b82f6;
  box-shadow: 0 6px 20px rgba(30, 58, 95, 0.35);
}

[data-theme="light"] .task-card.completed {
  background: rgba(30, 58, 95, 0.1);
  border-color: rgba(30, 58, 95, 0.25);
  border-left: 3px solid rgba(30, 58, 95, 0.6);
}

[data-theme="light"] .issue-card .explanation {
  background: rgba(30, 58, 95, 0.08);
  border-left: 3px solid #1E3A5F;
  color: #1E3A5F;
}

/* Light theme issue card status colors */
[data-theme="light"] .issue-card:has(.status-Resolved) {
  background: rgba(34, 197, 94, 0.08);
  border-color: rgba(34, 197, 94, 0.25);
}

[data-theme="light"] .issue-card:has(.status-Resolved):hover {
  border-color: rgba(34, 197, 94, 0.4);
  background: rgba(34, 197, 94, 0.15);
}

[data-theme="light"] .issue-card:has(.status-Resolved) h4 {
  color: #16a34a;
}

[data-theme="light"] .issue-card:has(.status-Assigned) {
  background: rgba(59, 130, 246, 0.08);
  border-color: rgba(59, 130, 246, 0.25);
}

[data-theme="light"] .issue-card:has(.status-Assigned):hover {
  border-color: rgba(59, 130, 246, 0.4);
  background: rgba(59, 130, 246, 0.15);
}

[data-theme="light"] .issue-card:has(.status-Assigned) h4 {
  color: #1E3A5F;
}

[data-theme="light"] .issue-card:has(.status-Rejected) {
  background: rgba(239, 68, 68, 0.08);
  border-color: rgba(239, 68, 68, 0.25);
}

[data-theme="light"] .issue-card:has(.status-Rejected):hover {
  border-color: rgba(239, 68, 68, 0.4);
  background: rgba(239, 68, 68, 0.15);
}

[data-theme="light"] .issue-card:has(.status-Rejected) h4 {
  color: #dc2626;
}

[data-theme="light"] .issue-card h4 {
  color: #1E3A5F;
}

[data-theme="light"] .issue-card-user p {
  color: #3b82f6;
}

[data-theme="light"] .issue-card p {
  color: #3b82f6;
}

/* Light theme task card status colors */
[data-theme="light"] .task-card:has(.status-Scheduled),
[data-theme="light"] .worker-task-card:has(.status-Scheduled) {
  background: rgba(59, 130, 246, 0.08) !important;
  border-color: rgba(59, 130, 246, 0.25) !important;
}

[data-theme="light"] .task-card:has(.status-Scheduled):hover,
[data-theme="light"] .worker-task-card:has(.status-Scheduled):hover {
  border-color: rgba(59, 130, 246, 0.4);
  background: rgba(59, 130, 246, 0.15);
}

[data-theme="light"] .task-card:has(.status-InProgress),
[data-theme="light"] .worker-task-card:has(.status-InProgress) {
  background: rgba(245, 158, 11, 0.08) !important;
  border-color: rgba(245, 158, 11, 0.25) !important;
}

[data-theme="light"] .task-card:has(.status-InProgress):hover,
[data-theme="light"] .worker-task-card:has(.status-InProgress):hover {
  border-color: rgba(245, 158, 11, 0.4);
  background: rgba(245, 158, 11, 0.15);
}

[data-theme="light"] .task-card:has(.status-InProgress) h4,
[data-theme="light"] .worker-task-card:has(.status-InProgress) h4 {
  color: #d97706 !important;
}

[data-theme="light"] .task-card:has(.status-Completed),
[data-theme="light"] .worker-task-card:has(.status-Completed) {
  background: rgba(34, 197, 94, 0.08) !important;
  border-color: rgba(34, 197, 94, 0.25) !important;
}

[data-theme="light"] .task-card:has(.status-Completed):hover,
[data-theme="light"] .worker-task-card:has(.status-Completed):hover {
  border-color: rgba(34, 197, 94, 0.4);
  background: rgba(34, 197, 94, 0.15);
}

[data-theme="light"] .task-card:has(.status-Completed) h4,
[data-theme="light"] .worker-task-card:has(.status-Completed) h4 {
  color: #16a34a !important;
}

[data-theme="light"] .task-card:has(.status-Rejected),
[data-theme="light"] .worker-task-card:has(.status-Rejected) {
  background: rgba(239, 68, 68, 0.08) !important;
  border-color: rgba(239, 68, 68, 0.25) !important;
}

[data-theme="light"] .task-card:has(.status-Rejected):hover,
[data-theme="light"] .worker-task-card:has(.status-Rejected):hover {
  border-color: rgba(239, 68, 68, 0.4);
  background: rgba(239, 68, 68, 0.15);
}

[data-theme="light"] .task-card:has(.status-Rejected) h4,
[data-theme="light"] .worker-task-card:has(.status-Rejected) h4 {
  color: #dc2626 !important;
}

[data-theme="light"] .task-section h3 {
  color: #1E3A5F;
  border-bottom: 2px solid rgba(30, 58, 95, 0.15);
}

[data-theme="light"] .response-form textarea {
  border: 1px solid rgba(30, 58, 95, 0.2);
}

[data-theme="light"] .response-form textarea:focus {
  border-color: rgba(30, 58, 95, 0.6);
  background: rgba(30, 58, 95, 0.05);
  box-shadow: 0 0 0 2px rgba(30, 58, 95, 0.1);
}

[data-theme="light"] .chart-box {
  background: rgba(59, 130, 246, 0.04);
  border: 1px solid rgba(59, 130, 246, 0.12);
}

[data-theme="light"] .chart-box:hover {
  border-color: rgba(59, 130, 246, 0.3);
  background: rgba(59, 130, 246, 0.08);
  box-shadow: 0 4px 16px rgba(59, 130, 246, 0.08);
}

[data-theme="light"] .chart-box h3 {
  color: #1E3A5F;
}

[data-theme="light"] .task-card,
[data-theme="light"] .worker-card {
  background: rgba(59, 130, 246, 0.08);
  border: 1px solid rgba(59, 130, 246, 0.2);
}

[data-theme="light"] .task-card:hover,
[data-theme="light"] .worker-card:hover {
  border-color: rgba(59, 130, 246, 0.4);
  background: rgba(59, 130, 246, 0.15);
  box-shadow: 0 4px 12px rgba(59, 130, 246, 0.15);
}

[data-theme="light"] .task-card h4,
[data-theme="light"] .worker-card h4 {
  color: #1E3A5F;
}

[data-theme="light"] .task-card p,
[data-theme="light"] .worker-card p {
  color: #3b82f6;
}

[data-theme="light"] .priority-task-card.selected {
  border-color: rgba(59, 130, 246, 0.7);
  background: rgba(59, 130, 246, 0.12);
}

/* Responsive charts */
@media (max-width: 1024px) {
  .charts-container {
    grid-template-columns: 1fr;
  }

  .worker-task-columns {
    grid-template-columns: 1fr;
  }

  .worker-summary-grid {
    grid-template-columns: repeat(2, minmax(120px, 1fr));
  }
}

@media (max-width: 768px) {
  .section-head-row {
    align-items: stretch;
  }

  .refresh-btn,
  .user-action-btn,
  .location-btn,
  .form button,
  .form-reset-btn,
  .submit-btn,
  .complete-btn,
  .accept-btn,
  .reject-btn,
  .view-btn,
  .back-btn {
    width: 100%;
    justify-content: center;
  }

  .issue-map {
    height: 260px;
  }

  .chat-issue-select {
    min-width: 100%;
  }

  .chat-message-bubble {
    max-width: 96%;
  }

  .stats-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .worker-summary-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 480px) {
  .dashboard-content {
    padding: 8px;
  }

  .form {
    padding: 10px;
  }

  .issue-map {
    height: 220px;
  }

  .stats-grid,
  .worker-summary-grid,
  .analytics-grid {
    grid-template-columns: 1fr;
  }
}

